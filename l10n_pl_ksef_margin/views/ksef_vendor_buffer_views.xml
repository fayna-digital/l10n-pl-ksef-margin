<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view -->
    <record id="view_ksef_vendor_buffer_tree" model="ir.ui.view">
        <field name="name">ksef.vendor.buffer.tree</field>
        <field name="model">ksef.vendor.buffer</field>
        <field name="arch" type="xml">
            <tree decoration-success="state=='processed'"
                  decoration-info="state=='new'">
                <field name="name"/>
                <field name="invoice_number"/>
                <field name="vendor_name"/>
                <field name="vendor_nip"/>
                <field name="issue_date"/>
                <field name="due_date" optional="show"/>
                <field name="amount_net"/>
                <field name="amount_gross"/>
                <field name="currency_id" optional="hide"/>
                <field name="is_marza" optional="hide"/>
                <field name="xml_downloaded" optional="show" widget="boolean_toggle"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_ksef_vendor_buffer_form" model="ir.ui.view">
        <field name="name">ksef.vendor.buffer.form</field>
        <field name="model">ksef.vendor.buffer</field>
        <field name="arch" type="xml">
            <form string="KSeF Vendor Invoice">
                <header>
                    <!-- Download XML first (enables richer invoice creation) -->
                    <button name="action_download_xml"
                            string="Pobierz pełny XML z KSeF"
                            type="object"
                            class="btn-secondary"
                            invisible="xml_downloaded == True"
                            icon="fa-download"/>
                    <button name="action_create_vendor_invoice"
                            string="Utwórz fakturę w Odoo"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'processed'"/>
                    <button name="action_mark_processed"
                            string="Oznacz jako zaksięgowaną"
                            type="object"
                            invisible="state == 'processed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                type="object"
                                name="action_download_xml"
                                invisible="xml_downloaded == False"
                                icon="fa-file-code-o">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">XML</span>
                                <span class="o_stat_text">pobrany</span>
                            </div>
                        </button>
                        <button class="oe_stat_button"
                                type="object"
                                name="action_create_vendor_invoice"
                                invisible="not move_id"
                                icon="fa-file-text-o">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Faktura</span>
                                <span class="o_stat_text">w Odoo</span>
                            </div>
                        </button>
                    </div>

                    <group>
                        <group string="KSeF">
                            <field name="name" readonly="1"/>
                            <field name="invoice_number"/>
                            <field name="is_marza"/>
                        </group>
                        <group string="Sprzedawca">
                            <field name="vendor_name"/>
                            <field name="vendor_nip"/>
                        </group>
                    </group>
                    <group>
                        <group string="Daty">
                            <field name="issue_date"/>
                            <field name="receiving_date"/>
                            <field name="due_date"/>
                        </group>
                        <group string="Kwoty">
                            <field name="currency_id"/>
                            <field name="amount_net"/>
                            <field name="amount_gross"/>
                        </group>
                    </group>
                    <group string="Płatność" invisible="not payment_iban">
                        <field name="payment_iban"/>
                    </group>

                    <!-- XML attachment -->
                    <group string="XML KSeF" invisible="not xml_attachment_id">
                        <field name="xml_attachment_id" readonly="1"/>
                        <field name="xml_downloaded" readonly="1"/>
                    </group>

                    <!-- line_items_json must be declared for use in invisible modifier (Odoo 17 requirement) -->
                    <field name="line_items_json" invisible="1"/>

                    <!-- Parsed line items count (JSON stored internally, used when creating vendor bill) -->
                    <group string="Pozycje faktury (z XML)" invisible="not line_items_json">
                        <div class="text-muted small">
                            Позиції завантажено з XML і будуть автоматично підставлені при створенні фактури в Odoo.
                        </div>
                    </group>

                    <!-- Linked Odoo invoice -->
                    <group string="Faktura w Odoo" invisible="not move_id">
                        <field name="move_id" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ksef_vendor_buffer" model="ir.actions.act_window">
        <field name="name">KSeF — Faktury Przychodzące</field>
        <field name="res_model">ksef.vendor.buffer</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu root -->
    <menuitem id="menu_ksef_root"
              name="KSeF"
              parent="account.menu_finance"
              sequence="99"/>

    <menuitem id="menu_ksef_vendor_buffer"
              name="Faktury Przychodzące"
              parent="menu_ksef_root"
              action="action_ksef_vendor_buffer"
              sequence="10"/>

    <!-- Server action — gear menu in list -->
    <record id="action_ksef_sync_server" model="ir.actions.server">
        <field name="name">Synchronizuj z KSeF</field>
        <field name="model_id" ref="l10n_pl_ksef_margin.model_ksef_vendor_buffer"/>
        <field name="binding_model_id" ref="l10n_pl_ksef_margin.model_ksef_vendor_buffer"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">env['ksef.vendor.buffer'].action_sync_from_ksef()</field>
    </record>

    <!-- Direct menu item for sync -->
    <record id="action_ksef_sync_direct" model="ir.actions.server">
        <field name="name">KSeF — Synchronizuj z KSeF</field>
        <field name="model_id" ref="l10n_pl_ksef_margin.model_ksef_vendor_buffer"/>
        <field name="state">code</field>
        <field name="code">action = env['ksef.vendor.buffer'].action_sync_from_ksef()</field>
    </record>

    <menuitem id="menu_ksef_sync"
              name="Synchronizuj z KSeF"
              parent="menu_ksef_root"
              action="action_ksef_sync_direct"
              sequence="20"/>

</odoo>
