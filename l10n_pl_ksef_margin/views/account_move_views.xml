<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form view: KSeF tab ────────────────────────────────────── -->
    <record id="view_move_form_ksef" model="ir.ui.view">
        <field name="name">account.move.form.ksef</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="KSeF" invisible="move_type not in ['out_invoice', 'out_refund']">

                    <group>
                        <group string="Status KSeF">
                            <field name="l10n_pl_ksef_status" readonly="1"/>
                            <field name="l10n_pl_ksef_reference" readonly="1"/>
                            <field name="l10n_pl_ksef_upo_attachment_id" readonly="1"
                                   invisible="not l10n_pl_ksef_upo_attachment_id"/>
                        </group>
                    </group>

                    <div class="mt8">
                        <!-- Primary: send to KSeF -->
                        <button name="action_send_to_ksef"
                                string="Wyślij do KSeF"
                                type="object"
                                class="btn-primary"
                                invisible="l10n_pl_ksef_status in ['waiting', 'accepted']"/>

                        <!-- F-07: retry for rejected -->
                        <button name="action_retry_ksef"
                                string="Wyślij ponownie"
                                type="object"
                                class="btn-warning"
                                invisible="l10n_pl_ksef_status != 'rejected'"
                                confirm="Czy chcesz ponownie wysłać tę fakturę do KSeF?"/>

                        <!-- F-06: download UPO (only when accepted) -->
                        <button name="action_download_upo"
                                string="Pobierz UPO"
                                type="object"
                                class="btn-secondary"
                                invisible="l10n_pl_ksef_status != 'accepted'"
                                icon="fa-download"/>

                        <!-- Admin: manual reset -->
                        <button name="action_reset_ksef_status"
                                string="Resetuj status"
                                type="object"
                                class="btn-link text-muted"
                                invisible="l10n_pl_ksef_status not in ['rejected', 'waiting']"
                                confirm="Na pewno zresetować status KSeF do 'Not Sent'?"/>
                    </div>

                </page>
            </xpath>
        </field>
    </record>

    <!-- ── List view: KSeF status column ─────────────────────────── -->
    <record id="view_out_invoice_tree_ksef" model="ir.ui.view">
        <field name="name">account.move.list.ksef</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_state']" position="after">
                <field name="l10n_pl_ksef_status" string="KSeF" optional="show"
                       decoration-success="l10n_pl_ksef_status == 'accepted'"
                       decoration-warning="l10n_pl_ksef_status == 'waiting'"
                       decoration-danger="l10n_pl_ksef_status == 'rejected'"
                       decoration-muted="l10n_pl_ksef_status == 'draft'"/>
            </xpath>
        </field>
    </record>

    <!-- ── F-03: Bulk send — server action (gear menu in list) ───── -->
    <record id="action_ksef_bulk_send_server" model="ir.actions.server">
        <field name="name">KSeF — Wyślij zaznaczone faktury</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env['ksef.bulk.send.wizard'].with_context(active_ids=records.ids).create({}).action_confirm_dialog()
        </field>
    </record>

</odoo>
